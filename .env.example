# AI Ranger - Environment Variables
#
# Copy this file to .env and adjust values for your environment.
# The .env file is loaded by Docker Compose and must never be committed.
#
# All defaults below are safe for local development with `make dev`.
# Production deployments MUST change all passwords and secrets.

# =============================================================================
# Postgres — used by gateway (asyncpg) and workers (GORM)
# =============================================================================

# Postgres superuser credentials (used by the postgres container itself)
POSTGRES_USER=ranger
POSTGRES_PASSWORD=ranger
POSTGRES_DB=ranger
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Gateway connection URL (asyncpg driver for SQLAlchemy async)
GATEWAY_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Workers connection DSN (lib/pq format for GORM)
WORKERS_DATABASE_URL=host=${POSTGRES_HOST} port=${POSTGRES_PORT} user=${POSTGRES_USER} password=${POSTGRES_PASSWORD} dbname=${POSTGRES_DB} sslmode=disable

# =============================================================================
# ClickHouse — used by workers (ingest writer and API queries)
# =============================================================================

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=default

# =============================================================================
# RabbitMQ — used by gateway (publisher) and workers (consumer)
# =============================================================================

# RabbitMQ container default credentials (read natively by rabbitmq image)
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# AMQP connection URL (used by gateway and workers)
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672/

# =============================================================================
# Gateway — FastAPI ingest service (port 8080)
# =============================================================================

GATEWAY_PORT=8080

# Path to providers.toml, relative to the gateway working directory.
# In Docker this is /app; locally it is the gateway/ directory.
PROVIDERS_TOML_PATH=providers/providers.toml

# =============================================================================
# Workers — Go API server (port 8081) and ingest worker
# =============================================================================

API_SERVER_PORT=8081

# Graceful shutdown timeout in seconds for all services
SHUTDOWN_TIMEOUT_SECS=30

# =============================================================================
# Development seed data
# =============================================================================

# Plaintext enrollment token seeded into the database when ENVIRONMENT=development.
# The Alembic seed migration hashes this value with SHA256 before storing.
# If not set, the seed migration is skipped entirely.
# Production environments must NOT set this variable.
SEED_TOKEN=tok_test_dev

# =============================================================================
# Environment
# =============================================================================

# Set to "development" to enable seed data and debug features.
# Any other value (or unset) disables development-only behavior.
ENVIRONMENT=development
